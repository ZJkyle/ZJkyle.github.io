---
const techHighlights = [
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`,
    title: 'LLM 整合',
    description: '支援 vLLM、Ollama 等多種模型部署方案，靈活切換不同模型，不被單一供應商綁定。',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
    title: 'RAG Pipeline',
    description: '文件切割、Embedding、pgvector 向量搜尋，讓 AI 能精準回答你的領域知識問題。',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" /></svg>`,
    title: 'Speech-to-Text',
    description: 'Whisper 語音辨識 + Pyannote 說話者分離，自動產出帶有講者標記的逐字稿。',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /></svg>`,
    title: 'Multi-Agent 架構',
    description: '多個 AI Agent 協作處理複雜任務，自動拆解、分派、彙整，比單一模型更聰明。',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" /></svg>`,
    title: '全端整合',
    description: 'Next.js / SvelteKit 前端、FastAPI / Hono 後端、PostgreSQL 資料庫，一條龍打通。',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>`,
    title: 'Bot 生態系',
    description: 'Discord / Telegram Bot 即時收集資訊，串接你既有的工作流程，無需切換平台。',
  },
];
---

<section class="py-20">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">背後的技術</h2>
      <p class="mx-auto mt-3 max-w-xl text-sm text-slate-600">
        每款工具都建立在經過實戰驗證的 AI 技術棧上，不是玩具 Demo，是真正能跑的系統。
      </p>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {techHighlights.map(({ icon, title, description }) => (
        <div class="flex gap-4 rounded-xl border border-slate-100 bg-white p-6 shadow-sm">
          <div class="shrink-0 text-blue-600" set:html={icon} />
          <div>
            <h3 class="font-semibold text-slate-900">{title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-slate-600">{description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
