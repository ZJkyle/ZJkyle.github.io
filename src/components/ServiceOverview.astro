---
const items = [
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: '智慧資訊整理',
    description: '用 LLM 自動分類、標籤、搜尋你的筆記和會議記錄，讓碎片資訊變成可行動的知識庫。',
    tag: 'Glean',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    title: '文件自動處理',
    description: 'OCR + LLM 雙引擎辨識帳單和文件，自動擷取關鍵欄位並結構化儲存，告別手動輸入。',
    tag: 'AutoBill',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-1.997M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
    title: '社群化求職平台',
    description: '整合面試經驗、投遞追蹤、履歷產生，讓求職過程有系統、有社群、不再手忙腳亂。',
    tag: 'Radar',
  },
];
---

<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">我們的 AI 工具</h2>
      <p class="mx-auto mt-3 max-w-xl text-sm text-slate-600">
        每一款工具都從真實的痛點出發，用 AI 技術解決日常中最耗時的重複性工作。
      </p>
    </div>
    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      {items.map(({ icon, title, description, tag }) => (
        <a href="/products/" class="group block rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:border-blue-200 hover:shadow-md">
          <div class="flex items-center justify-between">
            <div class="text-blue-600" set:html={icon} />
            <span class="rounded-full bg-slate-100 px-3 py-0.5 text-xs font-medium text-slate-500">{tag}</span>
          </div>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">{title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
          <span class="mt-4 inline-block text-sm font-medium text-blue-600 opacity-0 transition-opacity group-hover:opacity-100">
            了解更多 &rarr;
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
