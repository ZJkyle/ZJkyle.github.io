---
const items = [
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: 'AI 工具開發',
    description: '幫你做出聊天機器人、智慧搜尋、自動分類、文件問答等 AI 功能，直接整合到你的產品裡。',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: 'Web App 開發',
    description: '從 0 到 1 幫你把想法做成可上線的網站或 App，前後端、資料庫、部署一條龍搞定。',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182" /></svg>`,
    title: '自動化與 Bot',
    description: '重複性的工作交給程式 -- Discord Bot、Telegram Bot、排程任務、資料串接，幫你省下大把時間。',
  },
];
---

<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">我能幫你做什麼</h2>
      <p class="mx-auto mt-3 max-w-xl text-sm text-slate-600">
        不管你是想做 Side Project、接案需要技術支援、還是想把日常工作自動化，都可以找我聊聊。
      </p>
    </div>
    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      {items.map(({ icon, title, description }) => (
        <div class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:border-blue-200 hover:shadow-md">
          <div class="text-blue-600" set:html={icon} />
          <h3 class="mt-5 text-lg font-semibold text-slate-900">{title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
          <a href="/services/" class="mt-4 inline-block text-sm font-medium text-blue-600 opacity-0 transition-opacity group-hover:opacity-100">
            了解更多 &rarr;
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
