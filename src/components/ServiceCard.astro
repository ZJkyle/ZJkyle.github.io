---
interface Props {
  title: string;
  description: string;
  forYou: string[];
  capabilities: string[];
}

const { title, description, forYou, capabilities } = Astro.props;
---

<div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <h2 class="text-xl font-bold text-slate-900">{title}</h2>
  <p class="mt-2 text-sm text-slate-600">{description}</p>

  <div class="mt-6">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-400">適合你如果</h3>
    <ul class="mt-2 space-y-1.5">
      {forYou.map((item) => (
        <li class="text-sm text-slate-600">
          <span class="mr-2 text-blue-400">&bull;</span>{item}
        </li>
      ))}
    </ul>
  </div>

  {capabilities.length > 0 && (
    <div class="mt-6">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-400">我能做的</h3>
      <ul class="mt-2 space-y-1.5">
        {capabilities.map((item) => (
          <li class="text-sm text-slate-600">
            <span class="mr-2 text-blue-400">&bull;</span>{item}
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
