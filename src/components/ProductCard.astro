---
import TechTag from './TechTag.astro';

interface Props {
  name: string;
  tagline: string;
  problem: string;
  features: string[];
  stack: string[];
}

const { name, tagline, problem, features, stack } = Astro.props;
---

<div class="border-b border-slate-200 pb-10">
  <h2 class="text-2xl font-bold text-slate-900">{name}</h2>
  <p class="mt-2 text-base text-teal-600">{tagline}</p>

  <div class="mt-6">
    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400">解決的問題</h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-500">{problem}</p>
  </div>

  <div class="mt-6">
    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400">核心功能</h3>
    <ul class="mt-3 space-y-1.5">
      {features.map((f) => (
        <li class="text-sm text-slate-600">
          <span class="mr-2 text-slate-300">&bull;</span>{f}
        </li>
      ))}
    </ul>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {stack.map((s) => <TechTag label={s} />)}
  </div>
</div>
