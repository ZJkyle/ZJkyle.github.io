---
import TechTag from './TechTag.astro';

interface Props {
  name: string;
  tagline: string;
  problem: string;
  features: string[];
  stack: string[];
  summary: string;
  github?: string;
  status: 'active' | 'beta' | 'planning';
  access: string;
}

const { name, tagline, problem, features, stack, summary, github, status, access } = Astro.props;

const statusClasses: Record<string, string> = {
  active: 'bg-emerald-50 text-emerald-700',
  beta: 'bg-amber-50 text-amber-700',
  planning: 'bg-slate-100 text-slate-600',
};

const statusLabels: Record<string, string> = {
  active: 'Active',
  beta: 'Beta',
  planning: 'Planning',
};
---

<div class="border-b border-slate-200 pb-10">
  <div class="flex items-start justify-between gap-4">
    <h2 class="text-2xl font-bold text-slate-900">{name}</h2>
    <div class="flex shrink-0 items-center gap-2">
      <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-medium', statusClasses[status]]}>
        {statusLabels[status]}
      </span>
      <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
        {access}
      </span>
    </div>
  </div>

  <p class="mt-3 text-sm font-medium text-slate-700">{summary}</p>
  <p class="mt-1 text-base text-teal-600">{tagline}</p>

  <div class="mt-6">
    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400">解決的問題</h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-500">{problem}</p>
  </div>

  <div class="mt-6">
    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400">核心功能</h3>
    <ul class="mt-3 space-y-1.5">
      {features.map((f) => (
        <li class="text-sm text-slate-600">
          <span class="mr-2 text-slate-300">&bull;</span>{f}
        </li>
      ))}
    </ul>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {stack.map((s) => <TechTag label={s} />)}
  </div>

  {github && (
    <div class="mt-6">
      <a href={github} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 transition-colors hover:text-slate-900">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  )}
</div>
