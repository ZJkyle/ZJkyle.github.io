---
import { categories, type Category } from '../data/categories';

interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
  tags?: string[];
  category?: Category;
}

const { title, date, description, slug, tags, category } = Astro.props;
const formattedDate = date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryColorClasses: Record<string, string> = {
  teal: 'bg-teal-50 text-teal-700',
  amber: 'bg-amber-50 text-amber-700',
  violet: 'bg-violet-50 text-violet-700',
};

const cat = category ? categories[category] : null;
---

<a href={`/blog/${slug}/`} class="group block border-b border-slate-100 pb-8">
  <div class="flex flex-wrap items-center gap-2">
    {cat && (
      <span class:list={['rounded-full px-2 py-0.5 text-[11px] font-semibold', categoryColorClasses[cat.color]]}>
        {cat.label}
      </span>
    )}
    <time class="text-xs text-slate-400">{formattedDate}</time>
    {tags && tags.map((tag) => (
      <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-500">{tag}</span>
    ))}
  </div>
  <h3 class="mt-1 text-lg font-bold text-slate-900 transition-colors group-hover:text-teal-600">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-500">{description}</p>
</a>
