---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={`/blog/${slug}/`} class="group block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:border-blue-200 hover:shadow-md">
  <time class="text-xs text-slate-400">{formattedDate}</time>
  <h3 class="mt-2 text-lg font-semibold text-slate-900 group-hover:text-blue-600">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
</a>
