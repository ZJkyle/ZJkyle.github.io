---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={`/blog/${slug}/`} class="group block border-b border-slate-100 pb-8">
  <time class="text-xs text-slate-400">{formattedDate}</time>
  <h3 class="mt-1 text-lg font-bold text-slate-900 transition-colors group-hover:text-teal-600">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-500">{description}</p>
</a>
