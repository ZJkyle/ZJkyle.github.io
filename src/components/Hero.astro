<section class="relative overflow-hidden bg-[#0f3d3e]">

  <!-- Video background -->
  <video
    class="absolute inset-0 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    poster="/hero-poster.jpg"
  >
    <source src="/hero-bg.mp4" type="video/mp4" />
  </video>

  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-black/40"></div>

  <!-- Content -->
  <div class="relative z-10">
    <div class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
      <div class="hero-stagger-1 flex items-center gap-3">
        <img src="/manatee-icon.svg" alt="Manatee" class="h-10 w-10 brightness-0 invert opacity-80" />
        <span class="text-2xl font-extrabold tracking-tight text-white sm:text-3xl">Manatee</span>
      </div>

      <h1 class="hero-stagger-2 mt-4 text-lg leading-relaxed text-teal-100/80 sm:text-xl">
        Hi, 我是 <span class="font-semibold text-white">Kyle</span> --
        <span class="text-teal-200">做工具、寫技術筆記</span>
      </h1>

      <p class="hero-stagger-3 mt-3 max-w-md text-sm leading-relaxed text-white/50">
        這裡有我做的開源工具、推薦的 AI 專案、還有拆解技術架構的文章。
      </p>

      <nav class="hero-stagger-4 mt-8 flex flex-wrap gap-3">
        <a href="/products/" class="rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-[#0f3d3e] transition-all hover:bg-teal-50">
          我做的工具
        </a>
        <a href="/board/" class="rounded-lg border border-white/30 px-5 py-2.5 text-sm font-medium text-white/90 transition-all hover:border-white/50 hover:text-white">
          AI 工具看板
        </a>
        <a href="/blog/" class="rounded-lg border border-white/30 px-5 py-2.5 text-sm font-medium text-white/90 transition-all hover:border-white/50 hover:text-white">
          技術文章
        </a>
      </nav>
    </div>
  </div>

  <!-- Wave transition -->
  <div class="absolute bottom-0 left-0 right-0 z-10">
    <svg class="wave-drift w-[200%]" viewBox="0 0 2400 48" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="height: 32px;">
      <path d="M0 28 C200 12, 400 40, 600 24 C800 8, 1000 36, 1200 28 C1400 20, 1600 40, 1800 22 C2000 4, 2200 34, 2400 28 L2400 48 L0 48 Z" fill="white" opacity="0.2"/>
      <path d="M0 34 C300 22, 500 42, 800 32 C1100 22, 1300 40, 1600 30 C1900 20, 2100 38, 2400 34 L2400 48 L0 48 Z" fill="white"/>
    </svg>
  </div>
</section>
