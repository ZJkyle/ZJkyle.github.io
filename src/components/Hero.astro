<section class="relative overflow-hidden" style="background: linear-gradient(165deg, #0f3d3e 0%, #0d4f50 30%, #11706b 60%, #1a8a7d 100%);">

  <!-- Noise texture -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 128px 128px;"></div>

  <!-- Subtle floating elements -->
  <div class="hero-fade absolute inset-0 overflow-hidden">
    <div class="float-slow absolute -top-16 right-[15%] h-[250px] w-[250px] rounded-full opacity-[0.07]" style="background: radial-gradient(circle, #5eead4 0%, transparent 70%);"></div>
    <div class="float-medium absolute bottom-[10%] left-[8%] h-[200px] w-[200px] rounded-full opacity-[0.06]" style="background: radial-gradient(circle, #99f6e4 0%, transparent 70%);"></div>
    <div class="float-slow absolute left-[15%] top-[25%] h-1.5 w-1.5 rounded-full bg-teal-300/20"></div>
    <div class="float-medium absolute right-[25%] top-[60%] h-1 w-1 rounded-full bg-white/15"></div>
    <div class="float-fast absolute left-[60%] top-[20%] h-1 w-1 rounded-full bg-teal-200/10"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10">
    <div class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
      <p class="hero-stagger-1 text-xs font-medium tracking-[0.2em] text-teal-200/60">
        TOOLS &middot; OPEN SOURCE &middot; ARCHITECTURE
      </p>

      <h1 class="hero-stagger-2 mt-4 text-3xl leading-[1.15] tracking-tight text-white sm:text-4xl">
        <span class="font-bold">獨立開發者的</span>
        <span class="font-serif italic text-teal-200">AI 工具實驗室</span>
      </h1>

      <p class="hero-stagger-3 mt-4 max-w-md text-sm leading-relaxed text-teal-100/50">
        一個人打造工具、推薦好用的開源專案、分享技術架構和實戰 Workflow。
      </p>

      <div class="hero-stagger-4 mt-8 flex gap-3">
        <a href="/products/" class="rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-[#0f3d3e] transition-all hover:bg-teal-50">
          探索工具
        </a>
        <a href="/board/" class="rounded-lg border border-teal-300/30 px-5 py-2.5 text-sm font-medium text-teal-100 transition-all hover:border-teal-200/50 hover:text-white">
          推薦看板
        </a>
      </div>
    </div>
  </div>

  <!-- Wave transition -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg class="wave-drift w-[200%]" viewBox="0 0 2400 48" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="height: 32px;">
      <path d="M0 28 C200 12, 400 40, 600 24 C800 8, 1000 36, 1200 28 C1400 20, 1600 40, 1800 22 C2000 4, 2200 34, 2400 28 L2400 48 L0 48 Z" fill="white" opacity="0.2"/>
      <path d="M0 34 C300 22, 500 42, 800 32 C1100 22, 1300 40, 1600 30 C1900 20, 2100 38, 2400 34 L2400 48 L0 48 Z" fill="white"/>
    </svg>
  </div>
</section>
