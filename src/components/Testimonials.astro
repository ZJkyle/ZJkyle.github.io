---
const useCases = [
  {
    problem: '每次開完會都要花 30 分鐘整理會議記錄，還常常漏掉重要的 Action Items。',
    solution: '用 Glean 錄音後自動轉文字、辨識講者、標記待辦事項，整理時間從 30 分鐘 -> 0。',
    tool: 'Glean',
  },
  {
    problem: '每個月收到幾十張帳單，手動 key-in 到 Excel 容易出錯又超耗時。',
    solution: '用 AutoBill 拍照上傳，AI 自動辨識金額、日期、品項，秒級完成結構化。',
    tool: 'AutoBill',
  },
  {
    problem: '求職季投了 30 幾間公司，用 Excel 追蹤到最後根本搞不清楚哪間到哪個階段。',
    solution: '用 Radar 一站管理所有投遞進度，還能看別人的面試經驗準備面試。',
    tool: 'Radar',
  },
];
---

<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">解決了什麼問題</h2>
      <p class="mx-auto mt-3 max-w-xl text-sm text-slate-600">
        每款工具都從一個真實的日常痛點出發。
      </p>
    </div>
    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      {useCases.map(({ problem, solution, tool }) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <span class="inline-block rounded-full bg-blue-50 px-3 py-0.5 text-xs font-medium text-blue-700">{tool}</span>
          <div class="mt-5">
            <p class="text-sm font-medium text-slate-400">Pain Point</p>
            <p class="mt-1 text-sm leading-relaxed text-slate-600">{problem}</p>
          </div>
          <div class="mt-5 border-t border-slate-100 pt-5">
            <p class="text-sm font-medium text-green-600">Solution</p>
            <p class="mt-1 text-sm leading-relaxed text-slate-700">{solution}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
