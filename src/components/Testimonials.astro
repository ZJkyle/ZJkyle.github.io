---
const testimonials = [
  {
    quote: '本來以為要花好幾個月才能做出來的東西，Kyle 兩週就交付了一個完整能用的版本，而且還主動幫我們加了 AI 分類功能。',
    name: '合作夥伴',
    role: 'Side Project 團隊',
  },
  {
    quote: '跟 Kyle 合作最大的感受是他真的會站在使用者的角度思考，不是只把功能做出來而已，而是會思考怎麼做才最好用。',
    name: '專案合作者',
    role: '全端開發',
  },
  {
    quote: '很少見到一個開發者同時能處理 AI 模型整合和前端 UI，溝通起來完全沒有隔閡，省了我們很多來回的時間。',
    name: '技術合作者',
    role: 'AI 產品開發',
  },
];
---

<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">合作過的人怎麼說</h2>
    </div>
    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      {testimonials.map(({ quote, name, role }) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <svg class="h-8 w-8 text-blue-200" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">{quote}</p>
          <div class="mt-6 border-t border-slate-100 pt-4">
            <p class="text-sm font-semibold text-slate-900">{name}</p>
            <p class="text-xs text-slate-400">{role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
