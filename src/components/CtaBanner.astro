---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '想找到最適合的 AI 工具？',
  description = '看看我的技術棧，或瀏覽技術文章了解背後的架構和 Workflow。',
} = Astro.props;
---

<section class="bg-slate-900 py-20">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-2xl font-bold text-white sm:text-3xl">{title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-slate-400">
      {description}
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href="/board/" class="w-full rounded-full bg-blue-600 px-8 py-3.5 text-sm font-medium text-white shadow-lg shadow-blue-600/25 transition-all hover:bg-blue-500 sm:w-auto">
        技術棧總覽
      </a>
      <a href="/blog/" class="w-full rounded-full border border-slate-600 px-8 py-3.5 text-sm font-medium text-slate-300 transition-colors hover:border-slate-500 hover:text-white sm:w-auto">
        閱讀技術文章
      </a>
    </div>
  </div>
</section>
