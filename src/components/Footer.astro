---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200">
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center">
      <div>
        <p class="text-sm font-extrabold tracking-tight text-slate-900">Manatee</p>
        <p class="mt-1 text-sm text-slate-400">AI 工具集合站</p>
      </div>
      <nav class="flex flex-wrap gap-6">
        <a href="/products/" class="text-sm text-slate-500 transition-colors hover:text-slate-900">工具</a>
        <a href="/board/" class="text-sm text-slate-500 transition-colors hover:text-slate-900">推薦看板</a>
        <a href="/blog/" class="text-sm text-slate-500 transition-colors hover:text-slate-900">技術文章</a>
        <a href="/about/" class="text-sm text-slate-500 transition-colors hover:text-slate-900">關於</a>
        <a href="https://github.com/ZJkyle" class="text-sm text-slate-500 transition-colors hover:text-slate-900" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
    <div class="mt-10 border-t border-slate-100 pt-6">
      <p class="text-xs text-slate-400">&copy; {year} Manatee</p>
    </div>
  </div>
</footer>
