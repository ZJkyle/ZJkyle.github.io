---
const year = new Date().getFullYear();

const navLinks = [
  { href: '/', label: '首頁' },
  { href: '/products/', label: '工具' },
  { href: '/board/', label: 'Board' },
  { href: '/blog/', label: '技術文章' },
  { href: '/about/', label: '關於' },
];

const toolLinks = [
  { label: 'Glean - 資訊整理' },
  { label: 'AutoBill - 帳單辨識' },
  { label: 'Radar - 求職追蹤' },
];
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-5xl px-6 py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <p class="text-lg font-bold text-slate-900">Manatee</p>
        <p class="mt-2 text-sm leading-relaxed text-slate-500">
          AI 工具集合站 -- 分享好用的開源 AI 工具、<br />
          技術文章與實戰架構。
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-400">頁面導覽</h3>
        <ul class="mt-4 space-y-2.5">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-slate-600 transition-colors hover:text-blue-600">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-400">工具</h3>
        <ul class="mt-4 space-y-2.5">
          {toolLinks.map(({ label }) => (
            <li>
              <a href="/products/" class="text-sm text-slate-600 transition-colors hover:text-blue-600">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-400">聯絡</h3>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a href="mailto:zhijiakyle@gmail.com" class="text-sm text-slate-600 transition-colors hover:text-blue-600">zhijiakyle@gmail.com</a>
          </li>
          <li>
            <a href="https://github.com/ZJkyle" class="text-sm text-slate-600 transition-colors hover:text-blue-600" target="_blank" rel="noopener">GitHub</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-slate-200 pt-8 text-center">
      <p class="text-xs text-slate-400">&copy; {year} Manatee. All rights reserved.</p>
    </div>
  </div>
</footer>
