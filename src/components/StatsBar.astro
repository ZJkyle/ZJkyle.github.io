---
const stats = [
  { value: '3+', label: '款自製 AI 工具' },
  { value: 'Open Source', label: '推薦好用的開源專案' },
  { value: 'Workflow', label: '分享實戰架構' },
  { value: 'Board', label: '追蹤主流工具動態' },
];
---

<section class="border-y border-slate-200 bg-white py-12">
  <div class="mx-auto grid max-w-5xl grid-cols-2 gap-8 px-6 sm:grid-cols-4">
    {stats.map(({ value, label }) => (
      <div class="text-center">
        <p class="text-2xl font-bold text-blue-600 sm:text-3xl">{value}</p>
        <p class="mt-1 text-sm text-slate-500">{label}</p>
      </div>
    ))}
  </div>
</section>
