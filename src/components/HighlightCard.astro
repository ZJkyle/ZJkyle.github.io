---
interface Props {
  name: string;
  description: string;
  href: string;
}

const { name, description, href } = Astro.props;
---

<a href={href} class="group block rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:border-blue-200 hover:shadow-md">
  <h3 class="text-xl font-semibold text-slate-900 group-hover:text-blue-600">{name}</h3>
  <p class="mt-3 text-sm leading-relaxed text-slate-600">{description}</p>
  <span class="mt-4 inline-block text-sm font-medium text-blue-600">了解更多 &rarr;</span>
</a>
