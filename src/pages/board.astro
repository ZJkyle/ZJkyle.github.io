---
import BaseLayout from '../layouts/BaseLayout.astro';
import { techLayers } from '../data/board';

const badgeClass: Record<string, string> = {
  using: 'bg-teal-50 text-teal-700',
  recommended: 'bg-amber-50 text-amber-700',
  planning: 'bg-slate-100 text-slate-500',
};

const badgeLabel: Record<string, string> = {
  using: 'Using',
  recommended: 'Recommended',
  planning: 'Planning',
};
---

<BaseLayout title="Tech Stack - Manatee" description="Kyle 的技術架構全覽 -- 從產品到基礎設施，每一層用了什麼工具、為什麼選它">
  <!-- Header -->
  <section class="border-b border-slate-100 py-16">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600">Tech Stack</p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">技術架構全覽</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-500">
        我的專案從產品層到基礎設施層，每一層分別用了哪些開源工具和框架。
        點擊任一層展開細節。
      </p>
      <div class="mt-4 flex flex-wrap gap-3 text-xs">
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block rounded bg-teal-50 px-1.5 py-0.5 font-medium text-teal-700">Using</span>
          <span class="text-slate-400">正在使用</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block rounded bg-amber-50 px-1.5 py-0.5 font-medium text-amber-700">Recommended</span>
          <span class="text-slate-400">推薦</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block rounded bg-slate-100 px-1.5 py-0.5 font-medium text-slate-500">Planning</span>
          <span class="text-slate-400">規劃中</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Architecture Diagram -->
  <section class="border-b border-slate-100 bg-slate-50 py-12">
    <div class="mx-auto max-w-4xl px-6">
      <div class="relative">
        {techLayers.map((layer, i) => (
          <div>
            {/* Connector line between layers */}
            {i > 0 && (
              <div class="flex justify-center py-1">
                <div class="h-4 w-px bg-slate-300"></div>
              </div>
            )}

            {/* Layer block */}
            <a
              href={`#${layer.id}`}
              class="arch-layer group block rounded-xl border-2 border-transparent bg-white p-4 shadow-sm transition-all hover:border-slate-300 hover:shadow-md"
            >
              {/* Layer header */}
              <div class="mb-3 flex items-center gap-2">
                <div class:list={['h-2.5 w-2.5 rounded-full', layer.color]} />
                <span class:list={['text-xs font-bold uppercase tracking-wider', layer.textColor]}>{layer.name}</span>
                <span class="text-[10px] text-slate-300">{layer.subtitle}</span>
              </div>

              {/* Tool chips */}
              <div class="flex flex-wrap gap-1.5">
                {layer.items.map((item) => (
                  <span class:list={[
                    'inline-block rounded-md border px-2.5 py-1 text-xs font-medium transition-colors',
                    item.badge === 'using'
                      ? 'border-teal-200 bg-teal-50 text-teal-800'
                      : item.badge === 'recommended'
                        ? 'border-amber-200 bg-amber-50 text-amber-800'
                        : item.badge === 'planning'
                          ? 'border-slate-200 bg-slate-50 text-slate-500'
                          : 'border-slate-200 bg-white text-slate-600',
                  ]}>
                    {item.name}
                  </span>
                ))}
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Detailed layers -->
  <div class="mx-auto max-w-5xl px-6 py-16">
    <div class="space-y-20">
      {techLayers.map((layer) => (
        <section id={layer.id}>
          <div class="flex items-center gap-3">
            <div class:list={['h-8 w-1 rounded-full', layer.color]} />
            <div>
              <h2 class:list={['text-lg font-bold', layer.textColor]}>{layer.name}</h2>
              <p class="text-sm text-slate-400">{layer.subtitle}</p>
            </div>
          </div>

          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {layer.items.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener"
                class="group flex flex-col rounded-lg border border-slate-200 p-5 transition-all hover:border-slate-300 hover:bg-slate-50"
              >
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-semibold text-slate-900 group-hover:text-teal-600">{item.name}</h3>
                  {item.badge && (
                    <span class:list={['shrink-0 rounded px-2 py-0.5 text-xs font-medium', badgeClass[item.badge]]}>
                      {badgeLabel[item.badge]}
                    </span>
                  )}
                </div>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-500">{item.description}</p>

                {item.note && (
                  <p class="mt-3 border-t border-slate-100 pt-3 text-xs text-slate-400">
                    {item.note}
                  </p>
                )}

                {item.usedIn && item.usedIn.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1">
                    {item.usedIn.map((project) => (
                      <span class="rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-medium text-slate-500">
                        {project}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
