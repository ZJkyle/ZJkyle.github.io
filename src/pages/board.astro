---
import BaseLayout from '../layouts/BaseLayout.astro';
import { techLayers } from '../data/board';

const badgeClass: Record<string, string> = {
  using: 'bg-teal-50 text-teal-700',
  recommended: 'bg-amber-50 text-amber-700',
  planning: 'bg-slate-100 text-slate-500',
};

const badgeLabel: Record<string, string> = {
  using: 'Using',
  recommended: 'Recommended',
  planning: 'Planning',
};

let toolIndex = 0;
---

<BaseLayout title="Tech Stack - Manatee" description="Kyle 的技術架構全覽 -- 從產品到基礎設施，每一層用了什麼工具、為什麼選它">
  <!-- Header -->
  <section class="border-b border-slate-100 py-16">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600">Tech Stack</p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">技術架構全覽</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-500">
        我的專案從產品層到基礎設施層，每一層分別用了哪些開源工具和框架。
        點擊任一工具展開細節。
      </p>
      <div class="mt-4 flex flex-wrap gap-3 text-xs">
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block rounded bg-teal-50 px-1.5 py-0.5 font-medium text-teal-700">Using</span>
          <span class="text-slate-400">正在使用</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block rounded bg-amber-50 px-1.5 py-0.5 font-medium text-amber-700">Recommended</span>
          <span class="text-slate-400">推薦</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block rounded bg-slate-100 px-1.5 py-0.5 font-medium text-slate-500">Planning</span>
          <span class="text-slate-400">規劃中</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Architecture Diagram with Inline Expandable Chips -->
  <section class="bg-slate-50 py-12">
    <div class="mx-auto max-w-4xl px-6">
      <div class="relative">
        {techLayers.map((layer, i) => (
          <div>
            {/* Connector line between layers */}
            {i > 0 && (
              <div class="flex justify-center py-1">
                <div class="h-6 w-px bg-slate-300"></div>
              </div>
            )}

            {/* Layer card */}
            <div class="rounded-xl bg-white p-5 shadow-sm">
              {/* Layer header */}
              <div class="mb-4 flex items-center gap-2">
                <div class:list={['h-3 w-3 rounded-full', layer.color]} />
                <span class:list={['text-sm font-bold uppercase tracking-wider', layer.textColor]}>{layer.name}</span>
                <span class="text-xs text-slate-400">{layer.subtitle}</span>
              </div>

              {/* Tool chips */}
              <div class="flex flex-wrap gap-2">
                {layer.items.map((item) => {
                  const id = `tool-${toolIndex++}`;
                  return (
                    <div class="tool-wrapper">
                      <button
                        type="button"
                        data-tool-id={id}
                        class:list={[
                          'tool-chip inline-flex items-center gap-1 rounded-md border px-3 py-1.5 text-xs font-medium transition-all cursor-pointer',
                          'hover:shadow-md focus:outline-none focus:ring-2 focus:ring-offset-1',
                          item.badge === 'using'
                            ? 'border-teal-300 bg-teal-50 text-teal-800 hover:bg-teal-100 focus:ring-teal-300'
                            : item.badge === 'recommended'
                              ? 'border-amber-300 bg-amber-50 text-amber-800 hover:bg-amber-100 focus:ring-amber-300'
                              : item.badge === 'planning'
                                ? 'border-slate-300 bg-slate-50 text-slate-600 hover:bg-slate-100 focus:ring-slate-300'
                                : 'border-slate-200 bg-white text-slate-600 hover:bg-slate-50 focus:ring-slate-300',
                        ]}
                      >
                        {item.name}
                        <svg class="tool-chevron h-3 w-3 text-current opacity-40 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                      </button>

                      {/* Inline detail panel (hidden by default) */}
                      <div id={id} class="tool-detail hidden mt-2 mb-1 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm">
                        <div class="flex items-start justify-between gap-3">
                          <h4 class="font-semibold text-slate-900">{item.name}</h4>
                          {item.badge && (
                            <span class:list={['shrink-0 rounded px-2 py-0.5 text-xs font-medium', badgeClass[item.badge]]}>
                              {badgeLabel[item.badge]}
                            </span>
                          )}
                        </div>
                        <p class="mt-2 leading-relaxed text-slate-600">{item.description}</p>
                        {item.note && (
                          <p class="mt-2 text-xs text-slate-400 italic">{item.note}</p>
                        )}
                        {item.usedIn && item.usedIn.length > 0 && (
                          <div class="mt-3 flex flex-wrap gap-1">
                            {item.usedIn.map((project) => (
                              <span class="rounded bg-white px-2 py-0.5 text-[10px] font-medium text-slate-500 border border-slate-200">
                                {project}
                              </span>
                            ))}
                          </div>
                        )}
                        <div class="mt-3 pt-2 border-t border-slate-200">
                          <a
                            href={item.url}
                            target="_blank"
                            rel="noopener"
                            class="inline-flex items-center gap-1 text-xs font-medium text-teal-600 hover:text-teal-800 transition-colors"
                          >
                            Open
                            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                          </a>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let openId: string | null = null;

      document.querySelectorAll('.tool-chip').forEach((btn) => {
        btn.addEventListener('click', () => {
          const targetId = (btn as HTMLElement).getAttribute('data-tool-id');
          if (!targetId) return;

          const targetPanel = document.getElementById(targetId);
          if (!targetPanel) return;

          // If clicking the already-open chip, close it
          if (openId === targetId) {
            targetPanel.classList.add('hidden');
            (btn as HTMLElement).querySelector('.tool-chevron')?.classList.remove('rotate-180');
            openId = null;
            return;
          }

          // Close the previously open panel
          if (openId) {
            const prevPanel = document.getElementById(openId);
            if (prevPanel) {
              prevPanel.classList.add('hidden');
            }
            // Reset the previous chip's chevron
            const prevBtn = document.querySelector(`[data-tool-id="${openId}"]`);
            if (prevBtn) {
              prevBtn.querySelector('.tool-chevron')?.classList.remove('rotate-180');
            }
          }

          // Open the new panel
          targetPanel.classList.remove('hidden');
          (btn as HTMLElement).querySelector('.tool-chevron')?.classList.add('rotate-180');
          openId = targetId;
        });
      });
    });
  </script>
</BaseLayout>
