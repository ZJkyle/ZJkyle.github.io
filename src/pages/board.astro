---
import BaseLayout from '../layouts/BaseLayout.astro';
import { boardCategories } from '../data/board';
---

<BaseLayout title="Board - Manatee" description="AI 工具推薦看板 -- 追蹤主流 Repo 和工具，按類別推薦最好用的方案">
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Board</h1>
      <p class="mt-3 text-sm text-slate-600">
        追蹤主流 AI 開源專案和工具，按類別推薦我認為最好用的方案。
        標有 <span class="inline-block rounded bg-blue-50 px-1.5 py-0.5 text-xs font-medium text-blue-700">Using</span> 的是我目前正在使用的，
        <span class="inline-block rounded bg-green-50 px-1.5 py-0.5 text-xs font-medium text-green-700">Recommended</span> 是我推薦但沒有在用的。
      </p>

      <div class="mt-12 space-y-12">
        {boardCategories.map(({ category, description, tools }) => (
          <div>
            <div class="border-b border-slate-200 pb-3">
              <h2 class="text-xl font-bold text-slate-900">{category}</h2>
              <p class="mt-1 text-sm text-slate-500">{description}</p>
            </div>
            <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {tools.map((tool) => (
                <a
                  href={tool.url}
                  target="_blank"
                  rel="noopener"
                  class="group block rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:border-blue-200 hover:shadow-md"
                >
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="font-semibold text-slate-900 group-hover:text-blue-600">{tool.name}</h3>
                    {tool.badge === 'using' && (
                      <span class="shrink-0 rounded bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700">Using</span>
                    )}
                    {tool.badge === 'recommended' && (
                      <span class="shrink-0 rounded bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">Recommended</span>
                    )}
                  </div>
                  <p class="mt-2 text-sm leading-relaxed text-slate-600">{tool.description}</p>
                  <span class="mt-3 inline-block text-xs font-medium text-blue-600 opacity-0 transition-opacity group-hover:opacity-100">
                    GitHub &rarr;
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
