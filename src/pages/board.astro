---
import BaseLayout from '../layouts/BaseLayout.astro';
import { boardCategories } from '../data/board';
---

<BaseLayout title="Board - Manatee" description="AI 工具推薦看板 -- 追蹤主流 Repo 和工具，按類別推薦最好用的方案">
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600">推薦看板</p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">工具推薦看板</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-500">
        按類別追蹤主流 AI 開源專案。
        <span class="inline-block rounded bg-teal-50 px-1.5 py-0.5 text-xs font-medium text-teal-700">Using</span> 是我正在使用的，
        <span class="inline-block rounded bg-amber-50 px-1.5 py-0.5 text-xs font-medium text-amber-700">Recommended</span> 是推薦的。
      </p>

      <nav class="mt-8 flex flex-wrap gap-2">
        {boardCategories.map(({ category }) => (
          <a
            href={`#${category.toLowerCase().replace(/\s+/g, '-')}`}
            class="rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-500 transition-colors hover:border-slate-300 hover:bg-slate-50 hover:text-slate-700"
          >
            {category}
          </a>
        ))}
      </nav>

      <div class="mt-16 space-y-16">
        {boardCategories.map(({ category, description, tools }) => (
          <div id={category.toLowerCase().replace(/\s+/g, '-')}>
            <h2 class="text-lg font-bold text-slate-900">{category}</h2>
            <p class="mt-1 text-sm text-slate-400">{description}</p>
            <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {tools.map((tool) => (
                <a
                  href={tool.url}
                  target="_blank"
                  rel="noopener"
                  class="group block rounded-lg border border-slate-200 p-5 transition-all hover:border-slate-300 hover:bg-slate-50"
                >
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="font-semibold text-slate-900 group-hover:text-teal-600">{tool.name}</h3>
                    {tool.badge === 'using' && (
                      <span class="shrink-0 rounded bg-teal-50 px-2 py-0.5 text-xs font-medium text-teal-700">Using</span>
                    )}
                    {tool.badge === 'recommended' && (
                      <span class="shrink-0 rounded bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">Recommended</span>
                    )}
                  </div>
                  <p class="mt-2 text-sm leading-relaxed text-slate-500">{tool.description}</p>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
