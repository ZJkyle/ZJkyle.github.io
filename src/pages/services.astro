---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Manatee">
  <section class="flex flex-1 items-center justify-center py-32">
    <div class="text-center">
      <h1 class="text-2xl font-bold text-slate-900">此頁面已移除</h1>
      <p class="mt-2 text-sm text-slate-600">請前往工具頁面或 Board 查看我們的內容。</p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="/products/" class="inline-block rounded-full bg-blue-600 px-6 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-blue-700">
          工具
        </a>
        <a href="/board/" class="inline-block rounded-full border border-slate-300 px-6 py-3 text-sm font-medium text-slate-700 shadow-sm transition-colors hover:bg-slate-50">
          Board
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
