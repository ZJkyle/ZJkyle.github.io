---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Manatee">
  <section class="flex flex-1 items-center justify-center py-32">
    <div class="text-center">
      <p class="text-6xl font-extrabold text-slate-200">404</p>
      <h1 class="mt-4 text-2xl font-bold text-slate-900">找不到頁面</h1>
      <p class="mt-2 text-sm text-slate-500">你要找的頁面不存在或已被移除。</p>
      <a href="/" class="mt-8 inline-block rounded-lg bg-slate-900 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-slate-800">
        回到首頁
      </a>
    </div>
  </section>
</BaseLayout>
