---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const entries = [
  {
    href: '/products/',
    label: '工具',
    title: '我們做的 AI 工具',
    description: '從會議記錄、帳單辨識到求職追蹤，每款都從真實痛點出發。',
  },
  {
    href: '/board/',
    label: 'Board',
    title: '工具推薦看板',
    description: '按類別追蹤主流 AI 開源專案，標註我在用的和我推薦的。',
  },
  {
    href: '/blog/',
    label: '文章',
    title: '技術文章',
    description: '拆解工具背後的技術決策、架構設計和 Workflow。',
  },
];
---

<BaseLayout title="Manatee - AI 工具集合站">
  <Hero />

  <!-- Entries -->
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-px overflow-hidden rounded-xl border border-slate-200 bg-slate-200 sm:grid-cols-3">
        {entries.map(({ href, label, title, description }) => (
          <a href={href} class="group flex flex-col justify-between bg-white p-8 transition-colors hover:bg-slate-50">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-teal-600">{label}</p>
              <h3 class="mt-3 text-lg font-bold text-slate-900">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-500">{description}</p>
            </div>
            <span class="mt-6 text-sm font-medium text-slate-400 transition-colors group-hover:text-slate-900">
              查看 &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest posts -->
  <section class="border-t border-slate-200 py-20">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600">最新文章</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-900">技術筆記</h2>
      <div class="mt-10 space-y-8">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.id}
          />
        ))}
      </div>
      <div class="mt-10">
        <a href="/blog/" class="text-sm font-medium text-slate-500 transition-colors hover:text-slate-900">
          查看所有文章 &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
