---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import ServiceOverview from '../components/ServiceOverview.astro';
import FeaturedCases from '../components/FeaturedCases.astro';
import Testimonials from '../components/Testimonials.astro';
import CtaBanner from '../components/CtaBanner.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Kyle Ko - 把你的點子變成真正能用的產品">
  <Hero />
  <StatsBar />
  <ServiceOverview />
  <FeaturedCases />
  <Testimonials />

  <section class="py-20">
    <div class="mx-auto max-w-3xl px-6">
      <div class="text-center">
        <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">最新文章</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm text-slate-600">
          技術筆記、開發心得、AI 實戰經驗分享。
        </p>
      </div>
      <div class="mt-10 space-y-6">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.id}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/blog/" class="text-sm font-medium text-blue-600 hover:underline">
          查看所有文章 &rarr;
        </a>
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>
