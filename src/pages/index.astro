---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const entries = [
  {
    href: '/products/',
    label: '工具',
    title: '我做的 AI 工具',
    description: '從會議記錄、帳單辨識到求職追蹤，每款都從真實痛點出發。',
    accent: 'teal' as const,
  },
  {
    href: '/board/',
    label: '推薦看板',
    title: '工具推薦看板',
    description: '按類別追蹤主流 AI 開源專案，標註我在用的和我推薦的。',
    accent: 'amber' as const,
  },
  {
    href: '/blog/',
    label: '文章',
    title: '技術文章',
    description: '拆解工具背後的技術決策、架構設計和 Workflow。',
    accent: 'violet' as const,
  },
];

const accentClasses: Record<string, { label: string; hoverBg: string; arrow: string }> = {
  teal: { label: 'text-teal-600', hoverBg: 'hover:bg-teal-50', arrow: 'group-hover:text-teal-600' },
  amber: { label: 'text-amber-600', hoverBg: 'hover:bg-amber-50', arrow: 'group-hover:text-amber-600' },
  violet: { label: 'text-violet-600', hoverBg: 'hover:bg-violet-50', arrow: 'group-hover:text-violet-600' },
};
---

<BaseLayout title="Manatee - AI 工具集合站">
  <Hero />

  <!-- Entries -->
  <section class="py-12">
    <div class="mx-auto max-w-3xl px-6">
      <div class="grid gap-px overflow-hidden rounded-xl border border-slate-200 bg-slate-200 sm:grid-cols-3">
        {entries.map(({ href, label, title, description, accent }) => {
          const classes = accentClasses[accent];
          return (
            <a href={href} class:list={['group flex flex-col justify-between bg-white p-6 transition-colors', classes.hoverBg]}>
              <div>
                <p class:list={['text-xs font-semibold uppercase tracking-widest', classes.label]}>{label}</p>
                <h3 class="mt-2 text-base font-bold text-slate-900">{title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-500">{description}</p>
              </div>
              <span class:list={['mt-4 text-sm font-medium text-slate-400 transition-colors', classes.arrow]}>
                查看 &rarr;
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Latest posts -->
  <section class="border-t border-slate-100 py-12">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-400">最新文章</h2>
      <ul class="mt-6 space-y-4">
        {posts.map((post) => {
          const cat = post.data.category ? categories[post.data.category] : categories.tech;
          const dotColor = { teal: 'bg-teal-500', amber: 'bg-amber-500', violet: 'bg-violet-500' };
          return (
            <li>
              <a href={`/blog/${post.id}/`} class="group flex items-baseline justify-between gap-4">
                <span class="flex items-center gap-2 text-sm font-medium text-slate-900 transition-colors group-hover:text-teal-600">
                  <span class:list={['inline-block h-1.5 w-1.5 shrink-0 rounded-full', dotColor[cat.color]]} />
                  {post.data.title}
                </span>
                <span class="shrink-0 text-xs text-slate-400">{post.data.date.toLocaleDateString('zh-TW', { month: 'short', day: 'numeric' })}</span>
              </a>
            </li>
          );
        })}
      </ul>
      <a href="/blog/" class="mt-6 inline-block text-sm font-medium text-slate-400 transition-colors hover:text-slate-900">
        所有文章 &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
