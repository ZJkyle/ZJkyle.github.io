---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { products } from '../data/products';
---

<BaseLayout title="作品集 - Kyle Ko">
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">作品集</h1>
      <p class="mt-3 text-sm text-slate-600">
        以下是我開發的產品與專案，涵蓋 AI 應用、全端開發與自動化系統。如果你有類似需求，歡迎<a href="/about/" class="text-blue-600 hover:underline">聯繫我</a>討論合作。
      </p>
      <div class="mt-12 grid gap-8">
        {products.map((p) => (
          <ProductCard {...p} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
