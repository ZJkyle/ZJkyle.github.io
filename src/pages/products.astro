---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { products } from '../data/products';
---

<BaseLayout title="工具 - Manatee">
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600">Tools</p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">AI 工具</h1>
      <p class="mt-3 max-w-2xl text-sm text-slate-500">
        我們自己打造的 AI 工具，每一款都從真實痛點出發。
      </p>
      <div class="mt-14 grid gap-10">
        {products.map((p) => (
          <ProductCard {...p} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
