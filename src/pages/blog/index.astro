---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="技術文章 - Manatee">
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-600">Blog</p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">技術文章</h1>
      <p class="mt-3 text-sm text-slate-500">技術筆記、架構拆解與觀點分享。</p>
      <div class="mt-14 space-y-8">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.id}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
